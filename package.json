{
  "name": "mcp-beebole",
  "version": "1.0.0",
  "description": "MCP server for Beebole time tracking",
  "author": "yciabaud",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yciabaud/mcp-beebole.git"
  },
  "bugs": {
    "url": "https://github.com/yciabaud/mcp-beebole/issues"
  },
  "homepage": "https://github.com/yciabaud/mcp-beebole#readme",
  "keywords": [
    "mcp",
    "beebole",
    "time-tracking",
    "model-context-protocol"
  ],
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "preinspect": "npm run build",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/github",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "package-lock.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "axios": "^1.8.1",
    "dotenv": "^16.4.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "semantic-release": "^24.2.9",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
